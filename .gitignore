dist/
node_modules/
.DS_Store
coverage/
*.tsbuildinfo

# intel-workbench workspaces build artifacts
packages/*/dist/
packages/server/dist/
packages/web/dist/
packages/web/node_modules/.vite/

# runtime data (落盘产物，不入库)：专题、审计链、用户配置、媒体任务
# 注意：用根锚定（前导 /），避免误伤同名的源码目录（如 packages/server/src/audit）。
/cases/
/audit/
/config/
/.cache/
/tasks/
/av-tasks/

# server 运行时落盘（cwd=packages/server 时产生：专题/审计链/用户配置），不入库
/packages/server/cases/
/packages/server/audit/
/packages/server/config/

# 本地开发/测试环境变量（含 API key，绝不入库）
/dev.env.sh
*.env.local
deploy/.env
deploy/.env.*
!deploy/.env.example
deploy/data/

__pycache__/
*.pyc
.mini-agent/
!.mini-agent/sessions/
!.mini-agent/logs/
!.mini-agent/artifacts/
