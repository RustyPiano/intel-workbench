# Intel Workbench offline deployment environment.
# Copy to a private env file before adding real keys. Keep real secrets out of git.
#
# Offline posture: the app uses an application-layer OfflineGuard that defaults
# to denying unlisted outbound hosts and allowlists only configured model
# endpoints. That is not a complete air gap by itself. For true zero-egress,
# also enforce OS, firewall, Docker, and network-layer isolation.

# Server runtime.
PORT=4319
WORKBENCH_DATA_DIR=/data
WORKBENCH_DEV_MODE=false
WORKBENCH_SKILLS_DIR=
WORKBENCH_BULLETIN_SCRIPT=

# Development-only Vite ports. Ignored by the built server image.
SERVER_PORT=4319
WEB_PORT=5319

# Primary text LLM. The placeholder key is non-secret and exists only because
# this server treats the text LLM as configured when model, base URL, and key
# are all non-empty.
MINI_AGENT_PROVIDER=openai-compatible
MINI_AGENT_MODEL=local-intel-llm
MINI_AGENT_BASE_URL=http://127.0.0.1:11434/v1
MINI_AGENT_API_KEY=local-placeholder-not-a-secret
OPENAI_API_KEY=

# Workbench behavior flags.
MINI_AGENT_DEMO=0
MINI_AGENT_INQUIRY_MODE=
MINI_AGENT_CTX_BUDGET_TOKENS=
MINI_AGENT_CONTEXTUAL_RETRIEVAL=false
MINI_AGENT_QUERY_REWRITE=off
MINI_AGENT_RERANK_MIN_CANDIDATES=8
MINI_AGENT_USE_MOCK_MEDIA=false
MINI_AGENT_CONTRADICTION_DEBUG=
MINI_AGENT_CONTRADICTION_JUDGE_THINKING=disabled

# Local binaries used by material processing.
MINI_AGENT_FFMPEG_BIN=ffmpeg
MINI_AGENT_FFPROBE_BIN=ffprobe
MINI_AGENT_LIT_BIN=lit
MINI_AGENT_DOC_MAX_PAGES=

# Offline media slots. ASR and OCR default to the known local services; VLM,
# embedding, and rerank are present but blank here to avoid enabling unverified
# placeholders at startup. Use deploy/model-profiles/local-models.env to fill
# them for your local model server.
MINI_AGENT_ASR_BASE_URL=http://127.0.0.1:8001
MINI_AGENT_ASR_MODEL=funasr-local
MINI_AGENT_ASR_API_KEY=
MINI_AGENT_ASR_DIM=
MINI_AGENT_ASR_PROVIDER=funasr

MINI_AGENT_OCR_BASE_URL=http://127.0.0.1:8000
MINI_AGENT_OCR_MODEL=paddleocr-local
MINI_AGENT_OCR_API_KEY=
MINI_AGENT_OCR_DIM=
MINI_AGENT_OCR_PROVIDER=

MINI_AGENT_VLM_BASE_URL=
MINI_AGENT_VLM_MODEL=
MINI_AGENT_VLM_API_KEY=
MINI_AGENT_VLM_DIM=
MINI_AGENT_VLM_PROVIDER=

MINI_AGENT_EMBED_BASE_URL=
MINI_AGENT_EMBED_MODEL=
MINI_AGENT_EMBED_API_KEY=
MINI_AGENT_EMBED_DIM=
MINI_AGENT_EMBED_PROVIDER=

MINI_AGENT_RERANK_BASE_URL=
MINI_AGENT_RERANK_MODEL=
MINI_AGENT_RERANK_API_KEY=
MINI_AGENT_RERANK_DIM=
MINI_AGENT_RERANK_PROVIDER=

# Lower-level mini-agent runtime settings. The deployed workbench server does
# not require these for normal operation, but production code reads them.
MINI_AGENT_SMOKE_PROVIDER=
MINI_AGENT_SMOKE_MODEL=
MINI_AGENT_SMOKE_BASE_URL=
MINI_AGENT_MM_PROVIDER=
MINI_AGENT_MM_MODEL=
MINI_AGENT_MM_BASE_URL=
MINI_AGENT_MM_API_KEY=
MINI_AGENT_MM_TIMEOUT_MS=
MINI_AGENT_ASR_APP_ID=
MINI_AGENT_ASR_ACCESS_KEY=
MINI_AGENT_ASR_APP_KEY=
MINI_AGENT_ASR_RESOURCE_ID=
MINI_AGENT_ASR_TIMEOUT_MS=
MINI_AGENT_ASR_TURBO_RESOURCE_ID=
MINI_AGENT_ASR_TURBO_MAX_BYTES=
MINI_AGENT_TOS_ACCESS_KEY_ID=
MINI_AGENT_TOS_ACCESS_KEY_SECRET=
MINI_AGENT_TOS_BUCKET=
MINI_AGENT_TOS_REGION=
MINI_AGENT_TOS_ENDPOINT=
MINI_AGENT_TOS_PREFIX=
MINI_AGENT_TOS_SIGNED_URL_EXPIRES=
MINI_AGENT_SESSION_DIR=
MINI_AGENT_MAX_TURNS=
MINI_AGENT_TOOL_TIMEOUT_MS=
MINI_AGENT_BASH_TIMEOUT_MS=
MINI_AGENT_MAX_BASH_OUTPUT_BYTES=
MINI_AGENT_READ_MAX_BYTES=
MINI_AGENT_GLOBAL_SKILL_DIRS=
MINI_AGENT_ALLOW_READ_OUTSIDE_WORKSPACE=false
MINI_AGENT_ALLOW_WRITE_OUTSIDE_WORKSPACE=false
MINI_AGENT_TRACE_MODE=compact
MINI_AGENT_SHOW_PLAN=true
MINI_AGENT_HIDE_DEBUG=false
MINI_AGENT_JSON_EVENTS=false
MINI_AGENT_READ_ONLY=false
