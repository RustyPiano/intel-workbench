# Local model-service profile for an offline Intel Workbench deployment.
# Merge these values into your private env file after replacing placeholders.

# Text LLM: OpenAI-compatible local chat/completions service.
MINI_AGENT_PROVIDER=openai-compatible
MINI_AGENT_MODEL=replace-with-local-chat-model
MINI_AGENT_BASE_URL=http://127.0.0.1:11434/v1
MINI_AGENT_API_KEY=local-placeholder-not-a-secret

# FunASR: external Python service, POST /asr, usually ../funasr on 127.0.0.1:8001.
MINI_AGENT_ASR_BASE_URL=http://127.0.0.1:8001
MINI_AGENT_ASR_MODEL=funasr-local
MINI_AGENT_ASR_API_KEY=
MINI_AGENT_ASR_DIM=
MINI_AGENT_ASR_PROVIDER=funasr

# PaddleOCR: external Python service, POST /ocr, usually ../paddleocr on 127.0.0.1:8000.
MINI_AGENT_OCR_BASE_URL=http://127.0.0.1:8000
MINI_AGENT_OCR_MODEL=paddleocr-local
MINI_AGENT_OCR_API_KEY=
MINI_AGENT_OCR_DIM=
MINI_AGENT_OCR_PROVIDER=

# VLM: OpenAI-compatible local multimodal chat/completions service.
MINI_AGENT_VLM_BASE_URL=http://127.0.0.1:11434/v1
MINI_AGENT_VLM_MODEL=replace-with-local-vlm-model
MINI_AGENT_VLM_API_KEY=
MINI_AGENT_VLM_DIM=
MINI_AGENT_VLM_PROVIDER=

# Embedding: OpenAI-compatible local /embeddings service; set DIM to the model vector size.
MINI_AGENT_EMBED_BASE_URL=http://127.0.0.1:11434/v1
MINI_AGENT_EMBED_MODEL=replace-with-local-embed-model
MINI_AGENT_EMBED_API_KEY=
MINI_AGENT_EMBED_DIM=replace-with-vector-dimension
MINI_AGENT_EMBED_PROVIDER=

# Rerank: local Jina/Cohere-style /rerank service.
MINI_AGENT_RERANK_BASE_URL=http://127.0.0.1:11434/v1
MINI_AGENT_RERANK_MODEL=replace-with-local-rerank-model
MINI_AGENT_RERANK_API_KEY=
MINI_AGENT_RERANK_DIM=
MINI_AGENT_RERANK_PROVIDER=
