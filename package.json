{
  "name": "mini-agent",
  "version": "1.1.0",
  "description": "A minimal local-first agent runtime with skills, tools, sessions, and a model adapter interface.",
  "type": "module",
  "bin": {
    "mini-agent": "./dist/src/cli/bin.js"
  },
  "files": [
    "dist/src/",
    ".agents/skills/",
    "docs/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "dev": "tsx src/cli/bin.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run test:run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/lib-storage": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.7",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
