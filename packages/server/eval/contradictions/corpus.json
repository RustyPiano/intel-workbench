{
  "chunks": [
    {
      "chunk_id": "c-001",
      "material_id": "doc-alpha",
      "text": "海湾行动“港湾黎明”在灰礁湾外线编组。观察员确认执行封控的巡逻艇为4艘。"
    },
    {
      "chunk_id": "c-002",
      "material_id": "doc-alpha",
      "text": "“红隼”营先遣队计划于3月14日06:00抵达北岸仓库。该时间由码头调度单复核。"
    },
    {
      "chunk_id": "c-003",
      "material_id": "doc-alpha",
      "text": "临时雷达站R-19设在东岬灯塔附属平台。报告称设备面向灰礁湾主航道。"
    },
    {
      "chunk_id": "c-004",
      "material_id": "doc-alpha",
      "text": "572号护卫舰仍在青港船坞维修。舰体动力测试尚未完成，不能参与本周部署。"
    },
    {
      "chunk_id": "c-005",
      "material_id": "doc-alpha",
      "text": "苍鹭无人机分队在南堤机场登记3架可用机。其余机体列为待检。"
    },
    {
      "chunk_id": "c-006",
      "material_id": "doc-bravo",
      "text": "“港湾黎明”行动通信主信道标记为第7信道。各艇每日08:00和20:00例行报到。"
    },
    {
      "chunk_id": "c-007",
      "material_id": "doc-bravo",
      "text": "灰礁湾外线封控由6艘巡逻艇执行。简报称所有艇均隶属“港湾黎明”行动。"
    },
    {
      "chunk_id": "c-008",
      "material_id": "doc-bravo",
      "text": "补给队B向北岸仓库派出18辆军用卡车。车辆清单由哨卡二号在17:40签收。"
    },
    {
      "chunk_id": "c-009",
      "material_id": "doc-bravo",
      "text": "同一补给队B晚间复盘称实际出车12辆。记录员注明没有第二批车辆。"
    },
    {
      "chunk_id": "c-010",
      "material_id": "doc-bravo",
      "text": "青港港区夜间宵禁将于4月2日00:00生效。通告覆盖东闸、南堤和北岸仓库。"
    },
    {
      "chunk_id": "c-011",
      "material_id": "doc-charlie",
      "text": "监听日志记录“青鲨”潜艇舷号为419。该艇在暗潮航道低速航行。"
    },
    {
      "chunk_id": "c-012",
      "material_id": "doc-charlie",
      "text": "铁路站台记录显示“红隼”营先遣队3月16日06:00才抵达北岸仓库。站务员称未见3月14日到场记录。"
    },
    {
      "chunk_id": "c-013",
      "material_id": "doc-charlie",
      "text": "西山油库库存保持稳定，柴油储量为260吨。两份库单均显示该数值。"
    },
    {
      "chunk_id": "c-014",
      "material_id": "doc-charlie",
      "text": "第七通信连当晚驻在北桥检查站。连部电台从北桥发出三次短报。"
    },
    {
      "chunk_id": "c-015",
      "material_id": "doc-charlie",
      "text": "同一夜间值班表注明第七通信连驻在南桥检查站。表内没有北桥岗位安排。"
    },
    {
      "chunk_id": "c-016",
      "material_id": "doc-delta",
      "text": "“灯塔”联络组的值班军官代号为蓝鹤。该代号用于4月1日全部加密报文。"
    },
    {
      "chunk_id": "c-017",
      "material_id": "doc-delta",
      "text": "银线车队定于22:30从西山油库出发。护送车先行十分钟离场。"
    },
    {
      "chunk_id": "c-018",
      "material_id": "doc-delta",
      "text": "工程队登记R-19临时雷达站位于西岬旧气象台。设备编号与东岬灯塔无关。"
    },
    {
      "chunk_id": "c-019",
      "material_id": "doc-delta",
      "text": "西山油库柴油储量为260吨。该数字与仓储主任的晨间口头报告一致。"
    },
    {
      "chunk_id": "c-020",
      "material_id": "doc-delta",
      "text": "北岸仓库外侧新增两处临时照明塔。照明塔只服务货场，不承担通信中继。"
    },
    {
      "chunk_id": "c-021",
      "material_id": "doc-echo",
      "text": "南堤机场放飞清单列出苍鹭无人机分队5架可用机。清单明确排除训练靶机。"
    },
    {
      "chunk_id": "c-022",
      "material_id": "doc-echo",
      "text": "北岸医疗后送线因桥面结冰暂停。调度员标注后送任务不得发车。"
    },
    {
      "chunk_id": "c-023",
      "material_id": "doc-echo",
      "text": "572号护卫舰已离开青港船坞并加入外线巡逻。港口摄像头在06:20拍到其出港。"
    },
    {
      "chunk_id": "c-024",
      "material_id": "doc-echo",
      "text": "声呐班报告“青鲨”潜艇舷号为491。记录员称舷号来自舰桥灯号。"
    },
    {
      "chunk_id": "c-025",
      "material_id": "doc-echo",
      "text": "同日后勤摘记称北岸医疗后送线已经恢复运行。第一辆救护车于19:15通过北桥。"
    },
    {
      "chunk_id": "c-026",
      "material_id": "doc-foxtrot",
      "text": "青港港区夜间宵禁推迟到4月5日00:00执行。港务处要求4月2日至4月4日保持常态通行。"
    },
    {
      "chunk_id": "c-027",
      "material_id": "doc-foxtrot",
      "text": "银线车队实际发车时间登记为23:10。门岗日志称22:30时车辆仍在装载。"
    },
    {
      "chunk_id": "c-028",
      "material_id": "doc-foxtrot",
      "text": "“港湾黎明”行动继续使用第7信道。通信员未报告备用信道切换。"
    },
    {
      "chunk_id": "c-029",
      "material_id": "doc-foxtrot",
      "text": "暗潮航道今晚潮位偏低，小型货船暂停通行。该限制不涉及军用巡逻艇。"
    },
    {
      "chunk_id": "c-030",
      "material_id": "doc-foxtrot",
      "text": "4月1日“灯塔”联络组值班军官代号为赤鸢。电台值守员称当日未使用蓝鹤代号。"
    }
  ],
